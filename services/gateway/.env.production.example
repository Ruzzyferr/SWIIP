# ConstChat Gateway — Production Environment

NODE_ENV=production
PORT=4001
LOG_LEVEL=info

# ── Redis (must be same instance as API) ──────
REDIS_URL=rediss://default:PASSWORD@host:25061

# ── Authentication (MUST match API JWT_SECRET) ─
JWT_SECRET=MUST_MATCH_API_JWT_SECRET

# ── Internal API URL ──────────────────────────
API_INTERNAL_URL=http://api:4000

# ── Public URL (for resume URL in READY event) ─
GATEWAY_PUBLIC_URL=wss://your-app.ondigitalocean.app/ws/gateway

# ── Connection Limits ─────────────────────────
MAX_CONNECTIONS=10000
HEARTBEAT_INTERVAL=41250
HEARTBEAT_TIMEOUT=20000
