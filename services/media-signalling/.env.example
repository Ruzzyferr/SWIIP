PORT=4002
NODE_ENV=development

# LiveKit SFU
# Use LiveKit Cloud: https://cloud.livekit.io
# Or self-hosted: docker run --rm -p 7880:7880 livekit/livekit-server --dev
LIVEKIT_URL=http://localhost:7880
LIVEKIT_WS_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# TURN server config (for NAT traversal in production)
# TURN_URL=turn:your-turn-server.com:3478
# TURN_USERNAME=constchat
# TURN_CREDENTIAL=your-turn-password

# JWT (same secret as API service for internal token validation)
JWT_SECRET=your-jwt-secret-change-this-in-production

# Redis
REDIS_URL=redis://localhost:6379

# NATS
NATS_URL=nats://localhost:4222

CORS_ORIGIN=http://localhost:3000
