NODE_ENV=production
PORT=4002
LOG_LEVEL=info

# Must match API/Gateway JWT secret
JWT_SECRET=CHANGE_ME_MIN_32_CHARS

# Internal dependencies
REDIS_URL=redis://redis:6379
NATS_URL=nats://nats:4222
CORS_ORIGIN=https://your-app.ondigitalocean.app

# LiveKit credentials
LIVEKIT_URL=http://livekit:7880
LIVEKIT_WS_URL=wss://your-app.ondigitalocean.app/livekit
LIVEKIT_API_KEY=CHANGE_ME
LIVEKIT_API_SECRET=CHANGE_ME_MIN_32_CHARS

# TURN server (coturn sidecar). Public host used by LiveKit to advertise
# relay candidates to clients; public IP used by coturn to bind external
# interface. Shared secret authenticates LiveKit ↔ coturn.
TURN_PUBLIC_HOST=turn.swiip.app
TURN_PUBLIC_IP=CHANGE_ME
TURN_SHARED_SECRET=CHANGE_ME_MIN_32_CHARS
