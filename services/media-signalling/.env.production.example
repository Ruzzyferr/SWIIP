NODE_ENV=production
PORT=4002
LOG_LEVEL=info

# Must match API/Gateway JWT secret
JWT_SECRET=CHANGE_ME_MIN_32_CHARS

# Internal dependencies
REDIS_URL=redis://redis:6379
NATS_URL=nats://nats:4222
CORS_ORIGIN=https://your-app.ondigitalocean.app

# LiveKit credentials
LIVEKIT_URL=https://your-livekit-host
LIVEKIT_WS_URL=wss://your-livekit-host
LIVEKIT_API_KEY=CHANGE_ME
LIVEKIT_API_SECRET=CHANGE_ME
