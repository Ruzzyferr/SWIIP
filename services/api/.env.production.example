# ConstChat API — Production Environment
# Copy to .env.production and fill in values

NODE_ENV=production
PORT=4000
LOG_LEVEL=info

# ── Database ──────────────────────────────────
DATABASE_URL=postgresql://doadmin:PASSWORD@host:25060/defaultdb?sslmode=require

# ── Redis ─────────────────────────────────────
REDIS_URL=rediss://default:PASSWORD@host:25061

# ── Authentication ────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=CHANGE_ME_MIN_32_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_MIN_32_CHARS
JWT_ACCESS_EXPIRY=15m
# Must be >= AUTH_COOKIE_MAX_AGE_SECONDS so the JWT does not expire while the
# cookie is still alive (which would force users to re-login mid-session).
JWT_REFRESH_EXPIRY=90d
AUTH_REFRESH_COOKIE_NAME=swiip_rt
# AUTH_COOKIE_DOMAIN:
#   - LEAVE UNSET (host-only) when web and api share the same origin via a
#     reverse proxy (e.g. swiip.app/ → web, swiip.app/api → api). This is the
#     default Swiip topology in infra/docker/Caddyfile.
#   - Set to ".yourdomain.com" only if you split api onto a sibling subdomain
#     (e.g. swiip.app + api.swiip.app) and need the cookie shared across both.
#   - Leave UNSET when web and api are on different *.ondigitalocean.app or
#     *.vercel.app subdomains (cross-site); also set SAMESITE=none in that case.
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_PATH=/
# AUTH_COOKIE_SAMESITE:
#   - "lax" for same-origin or same-site (recommended; CSRF-safe).
#   - "none" only when web and api are on different sites (cross-site XHR).
#     Requires Secure=true and a modern browser.
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_SECURE=true
# 90 days — matches SESSION_TTL_SECONDS in auth.service.ts and JWT_REFRESH_EXPIRY.
AUTH_COOKIE_MAX_AGE_SECONDS=7776000

# ── CORS ──────────────────────────────────────
CORS_ORIGIN=https://your-app.ondigitalocean.app
APP_URL=https://your-app.ondigitalocean.app

# ── Email (SMTP / Gmail) ──────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-address@gmail.com
SMTP_PASS=YOUR_GMAIL_APP_PASSWORD
SMTP_FROM=Swiip <your-address@gmail.com>
# Optional: prefer Brevo transactional API over SMTP when set
BREVO_API_KEY=

# ── Object Storage (DigitalOcean Spaces) ──────
S3_ENDPOINT=https://fra1.digitaloceanspaces.com
S3_BUCKET=constchat
S3_ACCESS_KEY=CHANGE_ME
S3_SECRET_KEY=CHANGE_ME
S3_REGION=fra1
S3_CDN_URL=https://constchat.fra1.cdn.digitaloceanspaces.com

# ── Optional Services ─────────────────────────
# NATS_URL=nats://host:4222
# MEILISEARCH_HOST=https://host:7700
# MEILISEARCH_KEY=masterKey
# SENTRY_DSN=https://...@sentry.io/...

# ── Upload Limits ─────────────────────────────
MAX_UPLOAD_SIZE_MB=100
