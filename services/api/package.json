{
  "name": "@constchat/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "jest --config jest.config.ts",
    "test:integration": "jest --config jest.config.ts --runInBand",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "ts-node prisma/seed.ts",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1019.0",
    "@aws-sdk/s3-request-presigner": "^3.1019.0",
    "@constchat/config": "workspace:*",
    "@fastify/cookie": "^9.4.0",
    "@fastify/static": "^7.0.4",
    "@nestjs/common": "^10.3",
    "@nestjs/config": "^3.2",
    "@nestjs/core": "^10.3",
    "@nestjs/event-emitter": "^2.0",
    "@nestjs/jwt": "^10.2",
    "@nestjs/passport": "^10.0",
    "@nestjs/platform-fastify": "^10.3",
    "@nestjs/swagger": "^7.3",
    "@nestjs/throttler": "^5.1",
    "@prisma/client": "^5.14",
    "bcryptjs": "^2.4",
    "class-transformer": "^0.5",
    "class-validator": "^0.14",
    "ioredis": "^5.4",
    "meilisearch": "^0.40",
    "multer": "^1.4",
    "nanoid": "^3.3",
    "nodemailer": "^8.0.4",
    "otplib": "^12.0",
    "passport": "^0.7",
    "passport-jwt": "^4.0",
    "passport-local": "^1.0",
    "pino": "^9.2",
    "pino-pretty": "^11.2",
    "prisma": "^5.14",
    "qrcode": "^1.5",
    "reflect-metadata": "^0.2",
    "rxjs": "^7.8",
    "sharp": "^0.33",
    "zod": "^3.23"
