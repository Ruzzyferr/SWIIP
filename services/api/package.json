  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3",
    "@nestjs/testing": "^10.3",
    "@types/bcryptjs": "^2.4",
    "@types/jest": "^30.0.0",
    "@types/multer": "^1.4",
    "@types/nodemailer": "^7.0.11",
    "@types/passport-jwt": "^4.0",
    "@types/passport-local": "^1.0",
    "@types/qrcode": "^1.5",
    "jest": "^30.0.5",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.1",
    "ts-node": "^10.9",
    "typescript": "^5.4"
