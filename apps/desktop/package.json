{
  "name": "@constchat/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Swiip Desktop Application",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --win --publish never",
    "build:installer": "electron-builder --win nsis --publish never",
    "build:portable": "electron-builder --win portable --publish never"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "electron-updater": "^6.2.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.swiip.desktop",
    "productName": "Swiip",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "src/**/*",
      "build/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "build/icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Swiip",
      "artifactName": "Swiip-Setup-${version}.${ext}"
    },
    "portable": {
      "artifactName": "Swiip-Portable-${version}.${ext}"
    },
    "publish": {
      "provider": "generic",
      "url": "https://swiip.app/downloads/"
    }
  }
}
