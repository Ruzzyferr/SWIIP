# Redirect www to apex
www.swiip.app {
    redir https://swiip.app{uri} permanent
}

swiip.app {
    # Static downloads (desktop app installer)
    @latestInstaller path /downloads/Swiip-Setup-latest.exe /downloads/Swiip-Setup-latest.exe.sha256
    handle @latestInstaller {
        header Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
        header Pragma "no-cache"
        root * /srv
        file_server
    }

    handle /downloads/* {
        header Cache-Control "public, max-age=31536000, immutable"
        root * /srv
        file_server
    }

    # API — strip /api prefix before proxying
    handle /api/* {
        uri strip_prefix /api
        reverse_proxy api:4000
    }

    # WebSocket gateway
    handle /gateway* {
        reverse_proxy gateway:4001
    }

    # LiveKit WebSocket/HTTP
    handle /livekit* {
        reverse_proxy livekit:7880
    }

    # Web frontend (catch-all)
    handle {
        reverse_proxy web:3000
    }
}
