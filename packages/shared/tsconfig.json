{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "incremental": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "exactOptionalPropertyTypes": false,
    "lib": ["ES2022", "DOM"],
    "paths": {
      "@constchat/protocol": ["../protocol/dist/index.d.ts"],
      "@constchat/design-tokens": ["../design-tokens/dist/index.d.ts"]
    }
  },
  "include": ["src"]
}
